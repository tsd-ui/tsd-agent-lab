<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>Label</key>
	<string>com.tsd-agent-lab.rotate-logs</string>
	<key>UserName</key>
	<string>agent-lab</string>
	<key>ProgramArguments</key>
	<array>
		<string>/Users/agent-lab/tsd-agent-lab/scripts/macos/rotate-logs.sh</string>
	</array>
	<key>WorkingDirectory</key>
	<string>/Users/agent-lab/tsd-agent-lab</string>
	<key>EnvironmentVariables</key>
	<dict>
		<key>HOME</key>
		<string>/Users/agent-lab</string>
		<key>PATH</key>
		<string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
	</dict>
	<key>StartCalendarInterval</key>
	<dict>
		<key>Weekday</key>
		<integer>0</integer>
		<key>Hour</key>
		<integer>4</integer>
		<key>Minute</key>
		<integer>0</integer>
	</dict>
	<key>StandardOutPath</key>
	<string>/Users/agent-lab/tsd-agent-lab/logs/rotate-logs.log</string>
	<key>StandardErrorPath</key>
	<string>/Users/agent-lab/tsd-agent-lab/logs/rotate-logs.log</string>
	<key>RunAtLoad</key>
	<false/>
</dict>
</plist>
