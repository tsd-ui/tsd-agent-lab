{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_vrtx_01W9515AEkcC4QbLjdNcjWBA","type":"tool_result","content":"1\tpub mod error;\n2\t\n3\tuse serde_json::Value;\n4\tpub use error::{ParseError, ValidationError};\n5\t\n6\t/// Supported configuration file formats.\n7\t#[derive(Debug, Clone, Copy, PartialEq, Eq)]\n8\tpub enum ConfigFormat {\n9\t    Toml,\n10\t    Yaml,\n11\t    Json,\n12\t}\n13\t\n14\timpl ConfigFormat {\n15\t    /// Detect format from a file extension.\n16\t    pub fn from_extension(ext: &str) -> Option<Self> {\n17\t        match ext {\n18\t            \"toml\" => Some(Self::Toml),\n19\t            \"yaml\" | \"yml\" => Some(Self::Yaml),\n20\t            \"json\" => Some(Self::Json),\n21\t            _ => None,\n22\t        }\n23\t    }\n24\t}\n25\t\n26\t/// Parse a configuration string into a JSON Value.\n27\tpub fn parse(input: &str, format: ConfigFormat) -> Result<Value, ParseError> {\n28\t    match format {\n29\t        ConfigFormat::Toml => {\n30\t            let table: toml::Value = toml::from_str(input)?;\n31\t            let json_str = serde_json::to_string(&table)?;\n32\t            Ok(serde_json::from_str(&json_str)?)\n33\t        }\n34\t        ConfigFormat::Yaml => Ok(serde_yaml::from_str(input)?),\n35\t        ConfigFormat::Json => Ok(serde_json::from_str(input)?),\n36\t    }\n37\t}\n38\t\n39\t/// A minimal schema representation for validation.\n40\t#[derive(Debug, Clone)]\n41\tpub struct Schema {\n42\t    pub required_keys: Vec<String>,\n43\t}\n44\t\n45\t/// Validate a parsed config value against a schema.\n46\tpub fn validate(value: &Value, schema: &Schema) -> Vec<ValidationError> {\n47\t    let mut errors = Vec::new();\n48\t    if let Some(obj) = value.as_object() {\n49\t        for key in &schema.required_keys {\n50\t            if !obj.contains_key(key) {\n51\t                errors.push(ValidationError::MissingKey(key.clone()));\n52\t            }\n53\t        }\n54\t    } else {\n55\t        errors.push(ValidationError::ExpectedObject);\n56\t    }\n57\t    errors\n58\t}\n59\t"}]},"parent_tool_use_id":null,"session_id":"80e7d795-b855-4bf0-a1e9-fa4a6df7fb25","uuid":"c0f4cdf4-c2f5-43f7-812f-e76cd0626a8b","timestamp":"2026-06-23T14:49:45.991Z","tool_use_result":{"type":"text","file":{"filePath":"/private/var/folders/38/_z2xr8rn0m33jpdp5jkbmd500000gn/T/agent-eval/2026-06-23-opus/cases/case-005-rust-monorepo/crates/config-core/src/lib.rs","content":"pub mod error;\n\nuse serde_json::Value;\npub use error::{ParseError, ValidationError};\n\n/// Supported configuration file formats.\n#[derive(Debug, Clone, Copy, PartialEq, Eq)]\npub enum ConfigFormat {\n    Toml,\n    Yaml,\n    Json,\n}\n\nimpl ConfigFormat {\n    /// Detect format from a file extension.\n    pub fn from_extension(ext: &str) -> Option<Self> {\n        match ext {\n            \"toml\" => Some(Self::Toml),\n            \"yaml\" | \"yml\" => Some(Self::Yaml),\n            \"json\" => Some(Self::Json),\n            _ => None,\n        }\n    }\n}\n\n/// Parse a configuration string into a JSON Value.\npub fn parse(input: &str, format: ConfigFormat) -> Result<Value, ParseError> {\n    match format {\n        ConfigFormat::Toml => {\n            let table: toml::Value = toml::from_str(input)?;\n            let json_str = serde_json::to_string(&table)?;\n            Ok(serde_json::from_str(&json_str)?)\n        }\n        ConfigFormat::Yaml => Ok(serde_yaml::from_str(input)?),\n        ConfigFormat::Json => Ok(serde_json::from_str(input)?),\n    }\n}\n\n/// A minimal schema representation for validation.\n#[derive(Debug, Clone)]\npub struct Schema {\n    pub required_keys: Vec<String>,\n}\n\n/// Validate a parsed config value against a schema.\npub fn validate(value: &Value, schema: &Schema) -> Vec<ValidationError> {\n    let mut errors = Vec::new();\n    if let Some(obj) = value.as_object() {\n        for key in &schema.required_keys {\n            if !obj.contains_key(key) {\n                errors.push(ValidationError::MissingKey(key.clone()));\n            }\n        }\n    } else {\n        errors.push(ValidationError::ExpectedObject);\n    }\n    errors\n}\n","numLines":59,"startLine":1,"totalLines":59}}}
