ord), bcrypt.DefaultCost)\n55\t\tif err != nil {\n56\t\t\treturn \"\", status.Error(codes.Internal, \"failed to hash password\")\n57\t\t}\n58\t\n59\t\tid, err := s.repo.CreateUser(ctx, email, string(hash))\n60\t\tif err != nil {\n61\t\t\treturn \"\", status.Error(codes.AlreadyExists, \"user already exists\")\n62\t\t}\n63\t\treturn id, nil\n64\t}\n65\t\n66\tfunc (s *Service) ValidateToken(ctx context.Context, tokenStr string) (string, error) {\n67\t\ttoken, err := jwt.Parse(tokenStr, func(t *jwt.Token) (interface{}, error) {\n68\t\t\tif _, ok := t.Method.(*jwt.SigningMethodHMAC); !ok {\n69\t\t\t\treturn nil, fmt.Errorf(\"unexpected signing method: %v\", t.Header[\"alg\"])\n70\t\t\t}\n71\t\t\treturn s.jwtSecret, nil\n72\t\t})\n73\t\tif err != nil || !token.Valid {\n74\t\t\treturn \"\", status.Error(codes.Unauthenticated, \"invalid token\")\n75\t\t}\n76\t\n77\t\tclaims, ok := token.Claims.(jwt.MapClaims)\n78\t\tif !ok {\n79\t\t\treturn \"\", status.Error(codes.Internal, \"invalid claims\")\n80\t\t}\n81\t\treturn claims[\"sub\"].(string), nil\n82\t}\n83\t\n84\tfunc (s *Service) generateToken(userID, email string) (string, error) {\n85\t\tclaims := jwt.MapClaims{\n86\t\t\t\"sub\":   userID,\n87\t\t\t\"email\": email,\n88\t\t\t\"exp\":   time.Now().Add(24 * time.Hour).Unix(),\n89\t\t\t\"iat\":   time.Now().Unix(),\n90\t\t}\n91\t\treturn jwt.NewWithClaims(jwt.SigningMethodHS256, claims).SignedString(s.jwtSecret)\n92\t}\n93\t"}]},"parent_tool_use_id":null,"session_id":"e24ff7d2-9a25-4890-9e2c-e75ccb54f2bd","uuid":"e69cc2e9-9a47-4b9d-bc21-f12591129c5a","timestamp":"2026-06-23T14:48:37.466Z","tool_use_result":{"type":"text","file":{"filePath":"/private/var/folders/38/_z2xr8rn0m33jpdp5jkbmd500000gn/T/agent-eval/2026-06-23-opus/cases/case-004-go-microservice/internal/auth/service.go","content":"package auth\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"time\"\n\n\t\"github.com/golang-jwt/jwt/v5\"\n\t\"go.uber.org/zap\"\n\t\"golang.org/x/crypto/bcrypt\"\n\t\"google.golang.org/grpc\"\n\t\"google.golang.org/grpc/codes\"\n\t\"google.golang.org/grpc/status\"\n\n\t\"github.com/example/auth-service/internal/cache\"\n)\n\ntype Service struct {\n\trepo      Repository\n\tcache     *cache.RedisCache\n\tjwtSecret []byte\n\tlogger    *zap.Logger\n}\n\nfunc NewService(repo Repository, cache *cache.RedisCache, secret string, logger *zap.Logger) *Service {\n\treturn &Service{repo: repo, cache: cache, jwtSecret: []byte(secret), logger: logger}\n}\n\nfunc (s *Service) Register(srv *grpc.Server) {\n\t// Register gRPC service implementation with the server\n}\n\nfunc (s *Service) Login(ctx context.Context, email, password string) (string, error) {\n\tuser, err := s.repo.GetUserByEmail(ctx, email)\n\tif err != nil {\n\t\treturn \"\", status.Error(codes.NotFound, \"user not found\")\n\t}\n\n\tif err := bcrypt.CompareHashAndPassword([]byte(user.PasswordHash), []byte(password)); err != nil {\n\t\treturn \"\", status.Error(codes.Unauthenticated, \"invalid credentials\")\n\t}\n\n\ttoken, err := s.generateToken(user.ID, user.Email)\n\tif err != nil {\n\t\ts.logger.Error(\"failed to generate token\", zap.Error(err))\n\t\treturn \"\", status.Error(codes.Internal, \"token generation failed\")\n\t}\n\n\t_ = s.cache.Set(ctx, fmt.Sprintf(\"token:%s\", user.ID), token, 24*time.Hour)\n\treturn token, nil\n}\n\nfunc (s *Service) CreateUser(ctx context.Context, email, password string) (string, error) {\n\thash, err := bcrypt.GenerateFromPassword([]byte(password), bcrypt.DefaultCost)\n\tif err != nil {\n\t\treturn \"\", status.Error(codes.Internal, \"failed to hash password\")\n\t}\n\n\tid, err := s.repo.CreateUser(ctx, email, string(hash))\n\tif err != nil {\n\t\treturn \"\", status.Error(codes.AlreadyExists, \"user already exists\")\n\t}\n\treturn id, nil\n}\n\nfunc (s *Service) ValidateToken(ctx context.Context, tokenStr string) (string, error) {\n\ttoken, err := jwt.Parse(tokenStr, func(t *jwt.Token) (interface{}, error) {\n\t\tif _, ok := t.Method.(*jwt.SigningMethodHMAC); !ok {\n\t\t\treturn nil, fmt.Errorf(\"unexpected signing method: %v\", t.Header[\"alg\"])\n\t\t}\n\t\treturn s.jwtSecret, nil\n\t})\n\tif err != nil || !token.Valid {\n\t\treturn \"\", status.Error(codes.Unauthenticated, \"invalid token\")\n\t}\n\n\tclaims, ok := token.Claims.(jwt.MapClaims)\n\tif !ok {\n\t\treturn \"\", status.Error(codes.Internal, \"invalid claims\")\n\t}\n\treturn claims[\"sub\"].(string), nil\n}\n\nfunc (s *Service) generateToken(userID, email string) (string, error) {\n\tclaims := jwt.MapClaims{\n\t\t\"sub\":   userID,\n\t\t\"email\": email,\n\t\t\"exp\":   time.Now().Add(24 * time.Hour).Unix(),\n\t\t\"iat\":   time.Now().Unix(),\n\t}\n\treturn jwt.NewWithClaims(jwt.SigningMethodHS256, claims).SignedString(s.jwtSecret)\n}\n","numLines":93,"startLine":1,"totalLines":93}}}
